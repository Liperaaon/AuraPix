{
  "appId": "com.primestudios.aurapix",
  "appName": "AuraPix",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "http",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2500,
      "launchAutoHide": true,
      "backgroundColor": "#4F46E5",
      "showSpinner": false,
      "androidSplashResourceName": "splash"
    }
  }
}